# ============================================================
# Kai Agent for Windows â€” API Keys (all optional, auto-detected)
# ============================================================
# Copy this file to .env and fill in the keys you have.
# Kai Agent auto-detects what's available and uses the best one.
# If no keys are set, it falls back to Ollama (free, local).

# â”€â”€ LLM Providers (priority: Claude > OpenAI > Gemini > Ollama) â”€â”€
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# â”€â”€ Speech-to-Text â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Leave empty to use faster-whisper (free, local, runs on CPU)
DEEPGRAM_API_KEY=
# OPENAI_API_KEY also enables OpenAI Whisper if set above

# â”€â”€ Text-to-Speech â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Leave empty to use edge-tts (free, no key, Microsoft neural)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# â”€â”€ Web Search (for grounding LLM with live info) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Leave empty to use DuckDuckGo (free, no key)
TAVILY_API_KEY=

# â”€â”€ Ollama Settings â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
OLLAMA_HOST=http://localhost:11434
# Legacy single-model knob (used as fallback if the two below are empty)
OLLAMA_MODEL=llama3.2-vision
# Per-task model selection â€” vision = screen-aware, text = Code Mode / journal Q&A.
# Pick any model you've `ollama pull`'d. Tray â†’ Ollama â†’ "Pull recommended"
# downloads curated picks (qwen2-vl, llama3.2-vision, qwen2.5-coder, etc.)
OLLAMA_VISION_MODEL=
OLLAMA_TEXT_MODEL=

# â”€â”€ App Settings â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Hotkey to activate push-to-talk (default: ctrl+alt+space)
CLICKY_HOTKEY=ctrl+alt+space
# Whisper model size: tiny, base, small, medium (larger = slower but more accurate)
WHISPER_MODEL=base

